                { "type": "frame", "id": "image-error__icon", "x": 128, "y": 0, "width": 64, "height": 64, "fill": "#f0f2f5", "cornerRadius": 32, "layout": "none", "children": [{ "type": "text", "id": "image-error__icon-text", "x": 28, "y": 16, "content": "!", "fontSize": 24, "fontWeight": "700", "fill": "#999999" }] },
                { "type": "text", "id": "image-error__msg-title", "x": 124, "y": 88, "content": "加载失败", "fontSize": 18, "fontWeight": "700", "fill": "#333333" },
