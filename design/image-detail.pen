          "fill": "#ffffff",
          "cornerRadius": 12,
          "layout": "none",
          "children": [
            { "type": "text", "id": "image-preview__close", "x": 1160, "y": 20, "content": "✕", "fontSize": 24, "fill": "#999999" },
            {
              "type": "frame",
              "id": "image-preview__body",
              "x": 0,
              "y": 0,
              "width": 1200,
              "height": 900,
              "fill": "#ffffff",
              "cornerRadius": 12,
              "layout": "none",
              "children": [
                { "type": "frame", "id": "image-preview__img-area", "x": 40, "y": 40, "width": 760, "height": 820, "fill": "#f5f6f7", "layout": "none", "children": [] },
                {
                  "type": "frame",
                  "id": "image-preview__info-area",
                  "x": 840,
                  "y": 40,
                  "width": 320,
                  "height": 820,
                  "layout": "none",
                  "children": [
                    {
                      "type": "frame",
                      "id": "image-preview__author",
                      "x": 0,
                      "y": 0,
                      "width": 320,
                      "height": 48,
                      "layout": "none",
                      "children": [
                        { "type": "frame", "id": "image-preview__avatar", "x": 0, "y": 0, "width": 40, "height": 40, "fill": "#d9d9d9", "cornerRadius": 20, "layout": "none", "children": [] },
                        { "type": "text", "id": "image-preview__name", "x": 52, "y": 10, "content": "作者名称", "fontSize": 16, "fill": "#333333" }
                      ]
                    },
                    { "type": "frame", "id": "image-preview__collect", "x": 0, "y": 80, "width": 320, "height": 44, "fill": "#8b5cf6", "cornerRadius": 8, "layout": "none", "children": [{ "type": "text", "id": "image-preview__collect-text", "x": 110, "y": 12, "content": "采集到画板", "fontSize": 16, "fill": "#ffffff" }] },
                    { "type": "frame", "id": "image-preview__go-detail", "x": 0, "y": 140, "width": 320, "height": 40, "fill": "#ffffff", "stroke": { "align": "inside", "thickness": 1, "fill": "#e8e8e8" }, "cornerRadius": 8, "layout": "none", "children": [{ "type": "text", "id": "image-preview__detail-text", "x": 132, "y": 11, "content": "查看详情", "fontSize": 14, "fill": "#8b5cf6" }] }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "frame",
      "id": "image-loading-page",
