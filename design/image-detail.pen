{
  "version": "2.6",
  "children": [
    {
      "type": "frame",
      "id": "image-detail-page",
      "name": "图片详情页 - /image/:id",
      "x": 0,
      "y": 0,
      "width": 1440,
      "height": 1100,
      "fill": "#f5f6f7",
      "clip": true,
      "layout": "none",
      "children": [
        {
          "type": "frame",
          "id": "image-detail__header",
          "name": "Portal Header",
          "x": 0,
          "y": 0,
          "width": 1440,
          "height": 64,
          "fill": "#ffffff",
          "layout": "none",
          "effect": {
            "type": "shadow",
            "shadowType": "outer",
            "color": "#0000000a",
            "offset": { "x": 0, "y": 2 },
            "blur": 8,
            "spread": 0
          },
          "children": [
            { "type": "text", "id": "image-detail__logo", "x": 24, "y": 22, "content": "Pix Space", "fontSize": 20, "fontWeight": "bold", "fill": "#333333" },
            {
              "type": "frame",
              "id": "image-detail__search",
              "x": 320,
              "y": 12,
              "width": 800,
              "height": 40,
              "fill": "#f0f2f5",
              "cornerRadius": 20,
              "layout": "none",
              "children": [
                { "type": "text", "id": "image-detail__search-icon", "x": 16, "y": 11, "content": "🔍", "fontSize": 14, "fill": "#999999" },
                { "type": "text", "id": "image-detail__placeholder", "x": 40, "y": 11, "content": "搜索高品质素材、灵感...", "fontSize": 14, "fill": "#999999" }
              ]
            },
            {
              "type": "frame",
              "id": "image-detail__user-area",
              "x": 1296,
              "y": 16,
              "width": 120,
              "height": 32,
              "layout": "none",
              "children": [
                {
                  "type": "frame",
                  "id": "image-detail__upload",
                  "x": 0,
                  "y": 0,
                  "width": 72,
                  "height": 32,
                  "fill": "#8b5cf6",
                  "cornerRadius": 16,
                  "layout": "none",
                  "children": [{ "type": "text", "id": "image-detail__upload-text", "x": 22, "y": 8, "content": "上传", "fontSize": 14, "fill": "#ffffff" }]
                },
                {
                  "type": "frame",
                  "id": "image-detail__avatar",
                  "x": 88,
                  "y": 0,
                  "width": 32,
                  "height": 32,
                  "fill": "#d9d9d9",
                  "cornerRadius": 16,
                  "layout": "none",
                  "children": [{ "type": "text", "id": "image-detail__avatar-text", "x": 11, "y": 8, "content": "U", "fontSize": 14, "fill": "#ffffff" }]
                }
              ]
            }
          ]
        },
        {
          "type": "frame",
          "id": "image-detail__content-card",
          "name": "Detail Container",
          "x": 24,
          "y": 104,
          "width": 1392,
          "height": 920,
          "fill": "#ffffff",
          "cornerRadius": 12,
          "layout": "none",
          "effect": { "type": "shadow", "shadowType": "outer", "color": "#0000000d", "offset": { "x": 0, "y": 4 }, "blur": 16, "spread": 0 },
          "children": [
            {
              "type": "frame",
              "id": "image-detail__left-col",
              "name": "Image Area",
              "x": 0,
              "y": 0,
              "width": 980,
              "height": 920,
              "fill": "#fafafa",
              "layout": "none",
              "children": [
                {
                  "type": "frame",
                  "id": "image-detail__main-image",
                  "x": 40,
                  "y": 40,
                  "width": 900,
                  "height": 840,
                  "fill": "#eeeeee",
                  "layout": "none",
                  "children": [{ "type": "text", "id": "image-detail__img-placeholder", "x": 408, "y": 412, "content": "IMAGE_PLACEHOLDER", "fontSize": 14, "fill": "#999999" }]
                }
              ]
            },
            {
              "type": "frame",
              "id": "image-detail__right-col",
              "name": "Info Area",
              "x": 980,
              "y": 0,
              "width": 412,
              "height": 920,
              "layout": "none",
              "children": [
                {
                  "type": "frame",
                  "id": "image-detail__author-info",
                  "x": 24,
                  "y": 32,
                  "width": 312,
                  "height": 48,
                  "layout": "none",
                  "children": [
                    {
                      "type": "frame",
                      "id": "image-detail__auth-avatar",
                      "x": 0,
                      "y": 4,
                      "width": 40,
                      "height": 40,
                      "fill": "#d9d9d9",
                      "cornerRadius": 20,
                      "layout": "none",
                      "children": [{ "type": "text", "id": "image-detail__auth-avatar-text", "x": 14, "y": 13, "content": "A", "fontSize": 14, "fill": "#ffffff" }]
                    },
                    { "type": "text", "id": "image-detail__auth-name", "x": 52, "y": 8, "content": "作者名称", "fontSize": 16, "fontWeight": "600", "fill": "#333333" },
                    { "type": "text", "id": "image-detail__pub-time", "x": 52, "y": 28, "content": "2026-05-06 发布", "fontSize": 12, "fill": "#999999" }
                  ]
                },
                { "type": "text", "id": "image-detail__title", "x": 24, "y": 104, "content": "极简主义 3D 渲染图", "fontSize": 24, "fontWeight": "bold", "fill": "#333333" },
                {
                  "type": "frame",
                  "id": "image-detail__actions",
                  "x": 24,
                  "y": 160,
                  "width": 312,
                  "height": 100,
                  "layout": "none",
                  "children": [
                    { "type": "frame", "id": "image-detail__collect", "x": 0, "y": 0, "width": 312, "height": 44, "fill": "#8b5cf6", "cornerRadius": 8, "layout": "none", "children": [{ "type": "text", "id": "image-detail__collect-text", "x": 120, "y": 12, "content": "采集到画板", "fontSize": 16, "fill": "#ffffff" }] },
                    { "type": "frame", "id": "image-detail__download", "x": 0, "y": 56, "width": 96, "height": 40, "fill": "#ffffff", "stroke": { "align": "inside", "thickness": 1, "fill": "#e8e8e8" }, "cornerRadius": 8, "layout": "none", "children": [{ "type": "text", "id": "image-detail__download-text", "x": 33, "y": 11, "content": "下载", "fontSize": 14, "fill": "#8b5cf6" }] },
                    { "type": "frame", "id": "image-detail__like", "x": 108, "y": 56, "width": 96, "height": 40, "fill": "#ffffff", "stroke": { "align": "inside", "thickness": 1, "fill": "#e8e8e8" }, "cornerRadius": 8, "layout": "none", "children": [{ "type": "text", "id": "image-detail__like-text", "x": 38, "y": 11, "content": "赞", "fontSize": 14, "fill": "#8b5cf6" }] },
                    { "type": "frame", "id": "image-detail__share", "x": 216, "y": 56, "width": 96, "height": 40, "fill": "#ffffff", "stroke": { "align": "inside", "thickness": 1, "fill": "#e8e8e8" }, "cornerRadius": 8, "layout": "none", "children": [{ "type": "text", "id": "image-detail__share-text", "x": 38, "y": 11, "content": "分享", "fontSize": 14, "fill": "#8b5cf6" }] }
                  ]
                },
                {
                  "type": "frame",
                  "id": "image-detail__meta-info",
                  "x": 24,
                  "y": 300,
                  "width": 312,
                  "height": 120,
                  "layout": "none",
                  "children": [
                    { "type": "text", "id": "image-detail__meta-title", "x": 0, "y": 0, "content": "图片信息", "fontSize": 14, "fontWeight": "bold", "fill": "#333333" },
                    { "type": "text", "id": "image-detail__meta-size", "x": 0, "y": 32, "content": "尺寸：3840 x 2160 px", "fontSize": 13, "fill": "#666666" },
                    { "type": "text", "id": "image-detail__meta-format", "x": 0, "y": 56, "content": "格式：PNG", "fontSize": 13, "fill": "#666666" },
                    { "type": "text", "id": "image-detail__meta-weight", "x": 0, "y": 80, "content": "大小：4.2 MB", "fontSize": 13, "fill": "#666666" }
                  ]
                },
                {
                  "type": "frame",
                  "id": "image-detail__tags-section",
                  "x": 24,
                  "y": 440,
                  "width": 120,
                  "height": 56,
                  "layout": "none",
                  "children": [
                    { "type": "text", "id": "image-detail__tags-title", "x": 0, "y": 0, "content": "标签", "fontSize": 14, "fontWeight": "bold", "fill": "#333333" },
                    { "type": "frame", "id": "image-detail__tag-1", "x": 0, "y": 28, "width": 48, "height": 22, "fill": "#f0f2f5", "cornerRadius": 4, "layout": "none", "children": [{ "type": "text", "id": "image-detail__tag-text-1", "x": 8, "y": 4, "content": "3D渲染", "fontSize": 10, "fill": "#666666" }] },
                    { "type": "frame", "id": "image-detail__tag-2", "x": 56, "y": 28, "width": 36, "height": 22, "fill": "#f0f2f5", "cornerRadius": 4, "layout": "none", "children": [{ "type": "text", "id": "image-detail__tag-text-2", "x": 8, "y": 4, "content": "极简", "fontSize": 10, "fill": "#666666" }] }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "frame",
      "id": "image-preview-dialog-page",
      "name": "图片预览弹窗",
      "x": 0,
