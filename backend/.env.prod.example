# ╔══════════════════════════════════════════════════════════════╗
# ║              后端生产环境变量模板（复制为 .env.prod 后填写）    ║
# ╚══════════════════════════════════════════════════════════════╝
# 
# 使用方式（在项目根目录执行）：
#   1. cp backend/.env.prod.example backend/.env.prod
#   2. 编辑 backend/.env.prod，填入真实值
#   3. docker compose -f docker-compose.prod.yml --env-file backend/.env.prod up -d
#
# ⚠ .env.prod 包含密码，不要提交到 git！
#
# 本文件只放敏感值与部署相关值，供 docker-compose.prod.yml 的 ${VAR} 占位符替换。
# 非敏感连接信息（DB_URL / DB_USERNAME / REDIS_HOST / MINIO_ENDPOINT 等）写在 docker-compose.prod.yml 中。

# ── MySQL ──
# MYSQL_ROOT_PASSWORD 供 MySQL 容器初始化；DB_PASSWORD 同时用于 backend 连接与创建业务账号
MYSQL_ROOT_PASSWORD=changeme_root_2026
DB_PASSWORD=changeme_pix_2026

# ── Redis ──
REDIS_PASSWORD=changeme_redis_2026

# ── MinIO ──
MINIO_ACCESS_KEY=changeme_minio_admin
MINIO_SECRET_KEY=changeme_minio_secret_2026
MINIO_BUCKET=pix-space-prod

# ── CORS 允许的前端域名（多个用逗号分隔） ──
CORS_ALLOWED_ORIGINS=https://example.com
