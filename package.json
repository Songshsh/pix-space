{
  "name": "pix-space",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "prelint": "node -e \"const fs=require('fs'); if(!fs.existsSync('.eslintrc-auto-import.json')) fs.writeFileSync('.eslintrc-auto-import.json', '{\\\"globals\\\":{}}');\"",
    "lint": "npm run prelint && eslint . --ext .js,.vue,.ts,.tsx",
    "lint:style": "stylelint \"src/**/*.{css,vue}\"",
    "lint:style:fix": "stylelint \"src/**/*.{css,vue}\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:unit": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test": "npm run lint && npm run lint:style && npm run format:check && npm run typecheck && npm run test:unit",
    "test:all": "npm run test && npm run test:e2e && npm run build",
    "commit": "git-cz",
    "prepare": "husky"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@tanstack/vue-virtual": "^3.13.24",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.15.0",
    "element-plus": "^2.13.5",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.33",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@types/nprogress": "^0.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vitest/coverage-v8": "^4.1.4",
    "@vue/test-utils": "^2.4.6",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^9.33.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.4.0",
    "msw": "^2.11.3",
    "postcss-html": "^1.8.0",
    "prettier": "^3.8.1",
    "stylelint": "^16.21.1",
    "stylelint-config-standard-vue": "^1.0.0",
    "typescript": "^6.0.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^6.4.2",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^4.1.1",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "browser": true,
      "es2022": true,
      "node": true
    },
    "extends": [
      "eslint:recommended",
      "plugin:vue/vue3-recommended",
      "plugin:@typescript-eslint/recommended",
      "./.eslintrc-auto-import.json",
      "prettier"
    ],
    "parser": "vue-eslint-parser",
    "parserOptions": {
      "parser": "@typescript-eslint/parser",
      "ecmaVersion": "latest",
      "sourceType": "module",
      "extraFileExtensions": [
        ".vue"
      ]
    },
    "rules": {
      "vue/multi-word-component-names": "off",
      "@typescript-eslint/no-explicit-any": "warn",
      "@typescript-eslint/no-unused-vars": [
        "error",
        {
          "argsIgnorePattern": "^_"
        }
      ]
    }
  },
  "eslintIgnore": [
    "dist"
  ],
  "overrides": {
    "esbuild": "^0.25.0",
    "lodash": "^4.18.1",
    "tmp": "^0.2.5"
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.8.2"
  },
  "lint-staged": {
    "*.{js,ts,vue,jsx,tsx}": [
      "npm run prelint",
      "eslint --max-warnings 0",
      "prettier --write"
    ],
    "*.{css,scss,less,html,json,md}": [
      "prettier --write"
    ]
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
